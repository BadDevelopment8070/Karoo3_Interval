<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#05070B"
    android:padding="8dp">

    <ImageView
        android:id="@+id/graph"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:scaleType="fitXY"
        android:contentDescription="Power graph" />


    <LinearLayout
        android:id="@+id/top_telemetry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <TextView
            android:id="@+id/clock_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TIME --:--"
            android:textColor="#7FFBFF"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:gravity="center"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/speed_now"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SPD --.-"
            android:textColor="#00E5FF"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:gravity="center"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/heart_rate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="HR ---"
            android:textColor="#FF4D6D"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:gravity="center"
            android:includeFontPadding="false" />
    </LinearLayout>

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SMART FTP"
        android:textColor="#00E5FF"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:gravity="center"
        android:includeFontPadding="false" />

    <TextView
        android:id="@+id/timer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="10:00"
        android:textColor="#FFB000"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:gravity="center"
        android:includeFontPadding="false" />

    <TextView
        android:id="@+id/status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="WARMUP"
        android:textColor="#E8FFFF"
        android:fontFamily="monospace"
        android:gravity="center"
        android:textStyle="bold"
        android:includeFontPadding="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/power_now"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NOW ---W"
            android:textColor="#00E5FF"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/power_target"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TGT ---W"
            android:textColor="#FFB000"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/cadence"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CAD ---"
            android:textColor="#E8FFFF"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/segment_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:max="1000"
        android:progress="0" />

    <TextView
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SEG 1/1  FTP ---"
        android:textColor="#7FFBFF"
        android:fontFamily="monospace"
        android:gravity="center"
        android:includeFontPadding="false" />
</LinearLayout>
